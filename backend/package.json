    "@types/pg": "^8.11.10",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "typescript": "^5.7.2",
    "ts-node-dev": "^2.0.0",
    "ts-jest": "^29.2.5",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
